# PlantLab root environment example.
# Copy to `.env` for direct local backend runs only.
# Do not commit real `.env` files or secrets.

APP_ENV=development
PORT=8080

# Local SQLite default for direct backend experiments.
# Docker local development uses platform/infra/docker/docker-compose.local.yml
# and PostgreSQL instead.
PLANTLAB_DATABASE_URL=sqlite:///./data/platform.db

# DATABASE_URL can also be used.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# Cloud SQL / PostgreSQL settings. In production, DB_PASSWORD must come from
# Secret Manager and should not be written into this file.
DB_NAME=plantlab
DB_USER=plantlab_user
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
CLOUD_SQL_CONNECTION_NAME=plantlab-493805:us-central1:plantlab

PLANTLAB_STORAGE_BACKEND=local
PLANTLAB_UPLOAD_DIR=data/uploads
PLANTLAB_IMAGE_URL_STRATEGY=proxy

# Local development only. Replace in your untracked .env.
APP_SECRET_KEY=dev-only-change-me

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
PLANTLAB_APPLE_CLIENT_ID=com.plantlab.mobile
PLANTLAB_APPLE_WEB_CLIENT_ID=

GOOGLE_CLOUD_PROJECT=
GCS_BUCKET_NAME=

PLANTLAB_DEV_TOKEN_AUTH_ENABLED=true
PLANTLAB_STANDALONE_WEB_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
PLANTLAB_STANDALONE_MOBILE_SCHEME=plantlab

PLANTLAB_PROVISIONING_API_URL=http://localhost:3000
PLANTLAB_PROVISIONING_PUBLIC_URL=http://localhost:3000
PLANTLAB_PROVISIONING_SHARED_SECRET=dev-only-change-me
PLANTLAB_LOCAL_SETUP_URL=http://10.42.0.1:8080
PLANTLAB_DEVICE_PLATFORM_URL=http://localhost:8000
