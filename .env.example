APP_ENV=development
PORT=8080

PLANTLAB_DATABASE_URL=sqlite:///./data/platform.db
# DATABASE_URL can also be used. In production, use PostgreSQL.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# For Cloud Run, set DB_NAME, DB_USER, DB_PASSWORD, and CLOUD_SQL_CONNECTION_NAME.
# DB_PASSWORD should come from Secret Manager in production.
# For direct PostgreSQL connections, set DB_HOST instead of CLOUD_SQL_CONNECTION_NAME.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
CLOUD_SQL_CONNECTION_NAME=
# Run production schema changes from platform/ with: alembic upgrade head
PLANTLAB_STORAGE_BACKEND=local
PLANTLAB_UPLOAD_DIR=data/uploads
PLANTLAB_SESSION_SECRET=dev-only-change-me

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_CLOUD_PROJECT=
GCS_BUCKET_NAME=
