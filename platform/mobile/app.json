{
  "expo": {
    "name": "PlantLab",
    "slug": "plantlab-mobile",
    "scheme": "plantlab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/app-icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.plantlab.mobile",
      "buildNumber": "3",
      "icon": "./assets/app-icon-1024.png",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "PlantLab uses Bluetooth to find and provision PlantLab devices during setup.",
        "NSLocalNetworkUsageDescription": "PlantLab can connect to the device setup network for the compatibility SoftAP setup flow.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true,
          "bluetoothAlwaysPermission": "PlantLab uses Bluetooth to find and provision PlantLab devices during setup."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PlantLab uses the camera to scan the serial-number QR code on your device label."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-512.png",
        "backgroundColor": "#000000"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "backendApiBaseUrl": "",
      "router": {},
      "eas": {
        "projectId": "b503ff8e-be67-46b0-a3eb-b0224a1fdc18"
      }
    }
  }
}
