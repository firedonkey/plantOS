EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_AUTH_MODE=dev
EXPO_PUBLIC_ENABLE_DEV_AUTH=true
EXPO_PUBLIC_ENABLE_MOCK_FALLBACK=false
# Optional comma-separated SSID list for the mobile add-device Wi-Fi dropdown.
# iOS does not allow Expo apps to scan nearby Wi-Fi networks directly.
EXPO_PUBLIC_WIFI_SSID_OPTIONS=
